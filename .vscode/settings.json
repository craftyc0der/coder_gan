{
  "chat.tools.terminal.autoApprove": {
    "cargo run": true,
    "cargo test": true,
    "sed": true,
    "make": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    }
  }
}